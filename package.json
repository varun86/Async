{
  "name": "async-shell",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "electron/main.bundle.cjs",
  "scripts": {
    "build:main": "node esbuild.main.mjs",
    "build:main:watch": "node esbuild.main.mjs --watch",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "icons": "node scripts/export-app-icon.mjs",
    "readme:screenshots": "node scripts/export-readme-screenshots.mjs",
    "desktop": "npm run build && cross-env ASYNC_SHELL_LOAD_DIST=1 electron .",
    "dev": "npm run build:main && concurrently -k \"npm run build:main:watch\" \"vite\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "dev:debug": "npm run build:main && concurrently -k \"npm run build:main:watch\" \"vite\" \"wait-on http://127.0.0.1:5173 && cross-env ASYNC_SHELL_DEVTOOLS=1 electron .\"",
    "start:electron": "npm run desktop",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/diff": "^5.2.3",
    "@types/minimatch": "^5.1.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "41.1.0",
    "esbuild": "^0.24.2",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vite": "^6.0.3",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@chenglou/pretext": "^0.0.3",
    "@google/generative-ai": "^0.21.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.6.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "chokidar": "^3.6.0",
    "diff": "^5.2.0",
    "https-proxy-agent": "^8.0.0",
    "minimatch": "^9.0.9",
    "monaco-editor": "^0.52.0",
    "node-pty": "^1.1.0",
    "openai": "^4.96.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "typescript-language-server": "^5.1.3",
    "vscode-jsonrpc": "^8.2.1"
  }
}
